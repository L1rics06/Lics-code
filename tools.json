    {
        "type": "function",
        "function": {
            "name":"read_file",
            "description": "打开指定的文件",
            "parameters": {
                "type": "object",
                "properties": {
                    "file_path": {
                        "type": "string",
                        "description": "需要打开的文件相对路径，例如：./document.txt"
                    }
                },
                "required": ["file_path"]
            }
        }
    },
    {
        "type": "function",
