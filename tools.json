                "type": "object",
                "properties": {
                    "file_path": {
                        "type": "string",
                        "description": "需要追加的文件相对路径，例如：./document.txt"
                    },
                    "content": {
                        "type": "string",
                        "description": "需要追加到文件的内容，例如：这是一个测试文件。"
